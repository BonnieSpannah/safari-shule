  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "API requests / sec (5m)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m]))", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "5xx error rate (5m)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.02 } ] } } }
    },
    {
      "type": "timeseries",
      "title": "Request latency p95 (ms) per route",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route)) * 1000", "refId": "A", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "BullMQ queue depth",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "bullmq_queue_waiting", "refId": "A", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "type": "stat",
      "title": "SOS incidents (1h)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [{ "expr": "increase(safari_sos_incidents_total[1h])", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } }
    },
    {
      "type": "stat",
      "title": "M-Pesa callback failures (1h)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "targets": [{ "expr": "increase(safari_mpesa_callback_failures_total[1h])", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "DB connection pool utilization",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "prisma_pool_connections_busy", "refId": "A" }]
    }
  ],
