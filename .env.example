# =========================================================================
# Safari Shule — environment template
# Copy to .env and fill in real values. Never commit a real .env.
#
# Every value below is a DEFAULT that gets you a working local install.
# For production, change: JWT_ACCESS_SECRET, JWT_REFRESH_SECRET,
# DATA_ENCRYPTION_KEY, POSTGRES_PASSWORD, SUPER_ADMIN_PASSWORD, all provider
# secrets (AT_API_KEY, MPESA_*, TWILIO_*, INFOBIP_*), and SMTP creds.
#
# ---------------------------------------------------------------------------
# NOTE: This file drives the SERVER (API + Prisma + docker-compose). Browser-
# bundle variables (VITE_*) live in apps/web/.env.example → copy to
# apps/web/.env.local for local overrides. See docs/SETUP.md § "How the
# four env files fit together" for the full model.
# ---------------------------------------------------------------------------
# =========================================================================

# -------------------------------------------------------------------------
# Runtime — controls where the app "lives" (URLs, cookies, tenant subdomains)
# -------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3000                       # Backend port on your host
WEB_PORT=5173                       # Web console port on your host
APP_BASE_DOMAIN=safarishule.test    # e.g. safarishule.test locally · safarishule.co.ke in prod
WEB_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000
INTEGRATIONS_MODE=mock              # mock | live  — mock short-circuits SMS + M-Pesa

# -------------------------------------------------------------------------
# INITIAL SUPER ADMIN (created once by `pnpm db:seed`)
# These seed the platform's very first user. They can log in and create
# tenants (schools), invite users, and change every setting from the UI.
# You can change any of these later — this is just the bootstrap default.
# -------------------------------------------------------------------------
SUPER_ADMIN_FULL_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@safarishule.test        # Defaults to admin@<APP_BASE_DOMAIN> if unset
SUPER_ADMIN_PHONE=+254700000000
SUPER_ADMIN_PASSWORD=ChangeMe!Now1              # CHANGE this after first login (Profile → Security)


# -------------------------------------------------------------------------
# PostgreSQL (direct + pgbouncer)
# -------------------------------------------------------------------------
POSTGRES_USER=safari
POSTGRES_PASSWORD=safari
POSTGRES_DB=safari_shule
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Direct Postgres — no pgbouncer in dev.
DATABASE_URL=postgresql://safari:safari@localhost:5432/safari_shule?schema=public
# Uncomment the next line and swap DATABASE_URL to the pooled URL when running
# behind PgBouncer in production. Prisma needs the direct URL for migrations.
# DIRECT_URL=postgresql://safari:safari@localhost:5432/safari_shule?schema=public

# -------------------------------------------------------------------------
# Redis (cache, BullMQ, geospatial, pub/sub)
# -------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------------------
# JWT auth
# -------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -------------------------------------------------------------------------
# Africa's Talking (SMS) — default provider
# -------------------------------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SAFARISHULE
AT_DLR_CALLBACK_URL=https://api.safarishule.test/v1/integrations/at/dlr

# -------------------------------------------------------------------------
# SMS provider selection (auto | africas_talking | twilio | infobip | mock)
# `auto` = Africa's Talking when AT_API_KEY is set, otherwise mock
# -------------------------------------------------------------------------
SMS_PROVIDER=auto

# Twilio (optional secondary)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Infobip (optional tertiary)
INFOBIP_BASE_URL=
INFOBIP_API_KEY=
INFOBIP_SENDER_ID=SAFARISHULE

# -------------------------------------------------------------------------
# Mail provider selection (auto | mailhog | mailtrap | smtp | mock)
# `auto` = SMTP if SMTP_HOST is set, otherwise mock. Mailhog / Mailtrap use
# the SMTP_* block below with their respective hosts + credentials.
# -------------------------------------------------------------------------
MAIL_PROVIDER=auto

# -------------------------------------------------------------------------
# M-Pesa Daraja
# -------------------------------------------------------------------------
MPESA_ENV=sandbox       # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.safarishule.test/v1/integrations/mpesa/callback

# -------------------------------------------------------------------------
# SMTP / NodeMailer
# -------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Safari Shule <no-reply@safarishule.co.ke>"

# -------------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------------
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

# -------------------------------------------------------------------------
# Hardware ingestion
# -------------------------------------------------------------------------
HARDWARE_HMAC_REPLAY_WINDOW_SECONDS=300
HARDWARE_THROTTLE_PER_MINUTE=60
