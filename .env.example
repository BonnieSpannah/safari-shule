# =========================================================================
# Safari Shule — environment template
# Copy to .env and fill in real values. Never commit a real .env.
# =========================================================================

# -------------------------------------------------------------------------
# Runtime
# -------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
APP_BASE_DOMAIN=safarishule.local
WEB_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000
INTEGRATIONS_MODE=mock   # mock | live

# -------------------------------------------------------------------------
# PostgreSQL (direct + pgbouncer)
# -------------------------------------------------------------------------
POSTGRES_USER=safari
POSTGRES_PASSWORD=safari
POSTGRES_DB=safari_shule
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Direct connection used by Prisma migrate
DIRECT_URL=postgresql://safari:safari@localhost:5432/safari_shule?schema=public
# Pooled connection used by the running NestJS app (PgBouncer in tx mode)
DATABASE_URL=postgresql://safari:safari@localhost:6432/safari_shule?schema=public&pgbouncer=true&connection_limit=20

# -------------------------------------------------------------------------
# Redis (cache, BullMQ, geospatial, pub/sub)
# -------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------------------
# JWT auth
# -------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -------------------------------------------------------------------------
# Africa's Talking (SMS) — default provider
# -------------------------------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=SAFARISHULE
AT_DLR_CALLBACK_URL=https://api.safarishule.local/v1/integrations/at/dlr

# -------------------------------------------------------------------------
# SMS provider selection (auto | africas_talking | twilio | infobip | mock)
# `auto` = Africa's Talking when AT_API_KEY is set, otherwise mock
# -------------------------------------------------------------------------
SMS_PROVIDER=auto

# Twilio (optional secondary)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Infobip (optional tertiary)
INFOBIP_BASE_URL=
INFOBIP_API_KEY=
INFOBIP_SENDER_ID=SAFARISHULE

# -------------------------------------------------------------------------
# Mail provider selection (auto | mailhog | mailtrap | smtp | mock)
# `auto` = SMTP if SMTP_HOST is set, otherwise mock. Mailhog / Mailtrap use
# the SMTP_* block below with their respective hosts + credentials.
# -------------------------------------------------------------------------
MAIL_PROVIDER=auto

# -------------------------------------------------------------------------
# M-Pesa Daraja
# -------------------------------------------------------------------------
MPESA_ENV=sandbox       # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.safarishule.local/v1/integrations/mpesa/callback

# -------------------------------------------------------------------------
# SMTP / NodeMailer
# -------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Safari Shule <no-reply@safarishule.co.ke>"

# -------------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------------
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

# -------------------------------------------------------------------------
# Hardware ingestion
# -------------------------------------------------------------------------
HARDWARE_HMAC_REPLAY_WINDOW_SECONDS=300
HARDWARE_THROTTLE_PER_MINUTE=60
