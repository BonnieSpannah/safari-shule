# =========================================================================
# Web-only environment overrides — read by Vite at build time.
#
# COPY THIS FILE to apps/web/.env.local (which is gitignored) to override
# any of these locally. Only variables prefixed VITE_ are exposed to the
# browser bundle — server secrets (JWT, DB, provider keys) live in the
# ROOT .env and never leak here.
# =========================================================================

# Runtime API URL that the browser calls. Leave blank in dev to use Vite's
# built-in proxy (/v1 → localhost:3000). Set to http://127.0.0.1:3000 if
# you hit IPv6 lookup issues on macOS.
VITE_API_URL=

# Base domain the app expects — used to extract the tenant slug from the
# browser hostname (e.g. hillcrest.safarishule.test → tenant "hillcrest").
# Must match APP_BASE_DOMAIN in the ROOT .env.
VITE_BASE_DOMAIN=safarishule.test

# Default tenant slug when the app is loaded from localhost or the bare
# base domain (no subdomain to derive from). On a fresh install this is
# "platform" (the only tenant that exists). After you create your first
# school, change this to that school's slug for daily use, or (M2) use the
# tenant selector on the login page.
VITE_TENANT_SLUG=platform

# Optional map tiles (defaults to OpenStreetMap).
VITE_MAP_TILE_URL=
VITE_MAP_ATTRIBUTION=

# Optional Sentry / GlitchTip DSN for the browser bundle.
VITE_SENTRY_DSN=
