# Web-only environment overrides (vite reads these at build time).
# Runtime API URL — leave blank in dev to use the vite proxy (/v1 → :3000).
VITE_API_URL=

# Base domain the app expects (for tenant-subdomain extraction).
VITE_BASE_DOMAIN=safari-shule.test

# Default tenant slug used when the app is loaded from the bare base domain
# or from localhost (i.e. no subdomain to derive from). In production every
# tenant loads the app from their own subdomain — this default is a
# convenience for local demos.
VITE_TENANT_SLUG=hillcrest

# Optional map tiles (defaults to OpenStreetMap).
VITE_MAP_TILE_URL=
VITE_MAP_ATTRIBUTION=

# Optional Sentry / GlitchTip DSN for the browser bundle.
VITE_SENTRY_DSN=
