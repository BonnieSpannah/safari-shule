{
  "name": "@safari-shule/api",
  "version": "0.1.0",
  "private": true,
  "description": "Safari Shule API — multi-tenant school transport platform backend.",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=../../.env dist/prisma/seed.js"
  },
  "dependencies": {
    "@bull-board/api": "5.21.7",
    "@bull-board/express": "5.21.7",
    "@nestjs/bullmq": "10.2.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/platform-socket.io": "10.4.4",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/terminus": "10.2.3",
    "@nestjs/throttler": "6.2.1",
    "@nestjs/websockets": "10.4.4",
    "@prisma/client": "5.20.0",
    "@safari-shule/shared-types": "workspace:*",
    "@sentry/node": "8.30.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@willsoto/nestjs-prometheus": "6.0.1",
    "africastalking": "0.7.0",
    "argon2": "0.41.1",
    "axios": "1.7.7",
    "bullmq": "5.13.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.1",
    "libphonenumber-js": "1.11.10",
    "nestjs-pino": "4.1.0",
    "nodemailer": "6.9.15",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.2.2",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "4.7.5",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.13",
    "@types/node": "20.16.10",
    "@types/nodemailer": "6.4.16",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.8.0",
    "@typescript-eslint/parser": "8.8.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "prisma": "5.20.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@safari-shule/shared-types$": "<rootDir>/../../packages/shared-types/src"
    }
  }
}
